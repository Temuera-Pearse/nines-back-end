{
  "name": "nines-race-backend",
  "version": "1.0.0",
  "description": "Race-only backend for Nines horse racing game",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run typecheck:scripts",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "clean": "rm -rf dist",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:backfill:races": "tsx scripts/backfill-race-metadata.ts",
    "db:smoke:race": "tsx scripts/smoke-race-lifecycle.ts",
    "load:test": "tsx scripts/load-test.ts",
    "load:test:cluster": "tsx scripts/load-test-cluster.ts",
    "load:test:reconnect": "tsx scripts/load-reconnect-storm.ts",
    "load:test:soak": "tsx scripts/load-soak.ts",
    "load:test:compare": "tsx scripts/load-compare.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit"
  },
  "keywords": [
    "racing",
    "game",
    "websocket",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.664.0",
    "@aws-sdk/client-s3": "^3.664.0",
    "@aws-sdk/client-secrets-manager": "^3.664.0",
    "@aws-sdk/client-ssm": "^3.664.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "prom-client": "^14.2.0",
    "redis": "^4.6.13",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^2.0.15",
    "@types/ws": "^8.5.9",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^6.3.4",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
